# ==========================================================
# KITTY CONFIG
# ==========================================================
# Terminal: Kitty
# Fuente: JetBrainsMono Nerd Font
# Entorno pensado para Hyprland
# ==========================================================


# ==========================================================
# FONTS
# ==========================================================

# Fuente principal (Nerd Font para iconos)
font_family      family="JetBrainsMono Nerd Font Mono"

# Variantes automáticas
bold_font        auto
italic_font      auto
bold_italic_font auto


# ==========================================================
# TEMA
# ==========================================================

# Carga el esquema de colores desde archivo externo
# Permite cambiar el tema sin tocar el resto del config

# BEGIN_KITTY_THEME
# Pastel Cyberpunk
include current-theme.conf
# END_KITTY_THEME


# ==========================================================
# SCROLLBACK (historial)
# ==========================================================

# Número de líneas que guarda el historial
scrollback_lines 10000

# Cuando amplías la ventana rellena con historial anterior
scrollback_fill_enlarged_window yes

# Abre el historial con Neovim (Ctrl+Shift+h)
scrollback_pager nvim -c "set nowrap"

# Velocidad de scroll con la rueda
wheel_scroll_multiplier 5


# ==========================================================
# CURSOR
# ==========================================================

# Cursor estilo IDE (barra vertical)
cursor_shape beam

# Grosor del cursor
cursor_beam_thickness 1.5

# Estela visual al mover el cursor
cursor_trail 200

# Velocidad a la que desaparece la estela
cursor_trail_decay 0.1 0.4

# Movimiento mínimo antes de activar la estela
cursor_trail_start_threshold 2


# ==========================================================
# TERMINAL BELL
# ==========================================================

# Desactiva el beep molesto de terminal
enable_audio_bell no


# ==========================================================
# SHELL INTEGRATION
# ==========================================================

# Permite a kitty detectar comandos y mejorar scrollback
shell_integration enabled


# ==========================================================
# RATÓN
# ==========================================================

# Ocultar el cursor del ratón inmediatamente al escribir
mouse_hide_wait 0

# Copiar texto automáticamente al seleccionarlo
copy_on_select yes


# ==========================================================
# TRANSPARENCIA / BLUR
# ==========================================================

# Opacidad del fondo (1 = sólido)
background_opacity 0.7

# Blur fuerte del fondo (funciona con Hyprland)
background_blur 80

# Permite cambiar opacidad dinámicamente
dynamic_background_opacity yes


# ==========================================================
# DETECCIÓN DE LINKS
# ==========================================================

# Detecta URLs automáticamente
detect_urls yes

# Ctrl + click abre el enlace en el navegador
open_url_with default


# ==========================================================
# ATAJOS DE TECLADO
# ==========================================================

# Copiar texto al portapapeles
map ctrl+shift+c copy_to_clipboard

# Pegar desde el portapapeles
map ctrl+shift+v paste_from_clipboard


# ==========================================================
# RENDERIZADO Y FUENTES NERD
# ==========================================================

# Mejora compatibilidad de iconos Nerd Fonts
symbol_map U+E000-U+F8FF Symbols Nerd Font
allow_remote_control yes
